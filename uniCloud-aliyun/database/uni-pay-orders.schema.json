{
	"bsonType": "object",
	"required": ["status", "total_fee", "user_address.addstr", "user_address.userName", "user_address.telNumber"],
	"permission": {
		"read": true,
		"create": true,
		"update": true,
		"delete": false
	},
	"properties": {
		"_id": {
			"title": "订单id",
			"description": "ID，系统自动生成"
		},
		"order_no": {
			"title": "订单编号",
			"description": "订单编号"
		},
		"pdf_file_id":{
		    "bsonType": "string",
		    "description": "订单PDF文件id",
		    "title": "PDFid"
		  },
		  "pdf_file_url": {
		    "bsonType": "string",
		    "description": "订单PDF文件URL",
		    "title": "PDF链接"
		  },
		  "pdf_generated_at": {
		    "bsonType": "timestamp",
		    "description": "PDF生成时间",
		    "title": "PDF生成时间"
		  },
		
		"goods_list": {
			"title": "商品清单",
			"bsonType": "array",
			"description": "订单中包含的商品列表",
			"items": {
				"bsonType": "object",
				"properties": {
					"good_id": {
						"bsonType": "string",
						"title": "商品ID",
						"description": "对应goods表的_id"
					},
					"sku": {
						"bsonType": "string",
						"title": "SKU",
						"description": "商品SKU编码"
					},
					"name": {
						"bsonType": "string",
						"title": "商品名称"
					},
					"standard": {
						"bsonType": "string",
						"title": "规格"
					},
					"price": {
						"bsonType": "int",
						"title": "单价",
						"description": "单位：分"
					},
					"original_price": {
						"bsonType": "int",
						"title": "原价",
						"description": "单位：分"
					},
					"count": {
						"bsonType": "int",
						"title": "数量"
					},
					"total": {
						"bsonType": "int",
						"title": "小计",
						"description": "单位：分"
					},
					"image": {
						"bsonType": "string",
						"title": "商品图片",
						"description": "商品缩略图URL"
					}
				}
			}
		},
		"user_address": {
			"title": "收货信息",
			"bsonType": "object",
			"properties": {
				"street_name":{
					"bsonType": "string",
					"title": "乡镇街道办"
				},
				"street_code":{
					"bsonType": "string",
					"title": "乡镇街道办编码"
				},
				
				"addstr": {
					"bsonType": "string",
					"title": "详细地址"
				},
				"formatted_address": {
					"bsonType": "string",
					"title": "完整地址（自动拼接省市区+街道+详细地址）"
				},
				"alias": {
					"bsonType": "string",	
					"title": "地址别名"
				},
				
				"user_name": {
					"bsonType": "string",
					"title": "收件人"
				},
				"mobile": {
					"bsonType": "string",
					"title": "收件人号码"
				}
			}
		},
		"status": {
			"title": "订单状态",
			"bsonType": "int",
			"enum": [ {
				"text": "待发货",
				"value": 0
			}, {
				"text": "配送中",
				"value": 1
			}, {
				"text": "已收货",
				"value": 2
			}, {
				"text": "已取消",
				"value": 3
			},{
				"text": "已出单",
				"value": 4
			}],
			"description": "",
			"defaultValue": 0
		},
		
		
		"user_id": {
			"title": "用户ID",
			"bsonType": "string",
			"description": "用户id，参考uni-id-users表",
			"foreignKey": "uni-id-users._id",
			"forceDefaultValue": {
				"$env": "uid"
			}
		},
		"total_count": {
			"title": "订单总件数",
			"bsonType": "int",
			"description": "订单总件数"
		},
		"total_amount": {
			"title": "订单总金额",
			"bsonType": "int",
			"description": "订单总金额"
		},
		"actual_payment":{
			"title": "实际付款总金额",
			"bsonType": "int",
			"description": "实际付款总金额"
		},	
		"score_earned":{
			"title": "本单获得积分",
			"bsonType": "int"
		},
		"is_pre_order":{
			"title": "是否预售订单",
			"bsonType": "bool"	
		},	
		"create_date": {
			"title": "创建时间",
			"bsonType": "timestamp",
			"description": "创建时间",
			"forceDefaultValue": {
				"$env": "now"
			}
		},
		"cancel_date": {
			"title": "取消时间",
			"bsonType": "timestamp",
			"description": "订单取消时间"
		},
		"deliver_date": {
			"title": "发货时间",
			"bsonType": "timestamp",
			"description": "订单发货时间"
		},
		"receive_date": {
			"title": "成交时间",
			"bsonType": "timestamp",
			"description": "订单确认收货时间"
		},
		"update_date": {
			"bsonType": "timestamp",
			"defaultValue": {
				"$env": "now"
			},
			"description": "最后修改时间",
			"title": "最后修改时间"
		},
		
		
		"operater": {
			"bsonType": "string",
			"title": "操作员",
			"description": "操作员",
			"foreignKey": "uni-id-users._id"
		},
		
		"user_order_success": {
			"title": "回调状态",
			"bsonType": "bool",
			"description": "用户异步通知逻辑是否全部执行完成，且无异常（建议前端通过此参数是否为true来判断是否支付成功）"
		},
		"original_data": {
			"title": "异步通知原始数据",
			"bsonType": "object",
			"description": "异步回调通知返回的原始数据，微信v2是xml转json后的数据，微信v3和支付宝是原始json"
		},
		"notify_date": {
			"title": "异步通知时间",
			"bsonType": "timestamp",
			"description": "订单通知支付成功时间"
		}
	}
}, "index": [{
	"name": "idx_user_create",
	"key": {
		"user_id": 1,
		"create_date": -1
	}
}, {
	"name": "idx_status",
	"key": {
		"status": 1
	}
}]
}