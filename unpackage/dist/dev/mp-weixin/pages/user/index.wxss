
.user-container.data-v-79e6a490 {
  background-color: #f5f5f5;
  min-height: 100vh;
}
.user-header.data-v-79e6a490 {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 20px;
  margin-bottom: 10px;
}
.avatar.data-v-79e6a490 {
  width: 60px;
  height: 60px;
  border-radius: 30px;
  margin-right: 15px;
  background-color: #f0f0f0;
}
.user-info.data-v-79e6a490 {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.nickname.data-v-79e6a490 {
  font-size: 18px;
  font-weight: bold;
  color: #333;
}
.phone.data-v-79e6a490 {
  font-size: 14px;
  color: #999;
  margin-top: 5px;
}

/* 积分统计卡片样式 */
.score-section.data-v-79e6a490 {
  display: flex;
  background-color: #fff;
  padding: 15px 20px;
  margin-bottom: 10px;
  justify-content: space-around;
}
.score-item.data-v-79e6a490 {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.score-label.data-v-79e6a490 {
  font-size: 14px;
  color: #666;
}
.score-value.data-v-79e6a490 {
  font-size: 20px;
  font-weight: bold;
  color: #ff6000;
  margin-top: 5px;
}
.order-status-section.data-v-79e6a490 {
  background-color: #fff;
  padding: 12px;
  margin-bottom: 10px;
}
.order-status-card.data-v-79e6a490 {
  display: flex;
  align-items: center;
  padding: 12px 10px;
  margin-bottom: 8px;
  border-radius: 8px;
  background-color: #f9f9f9;
  border: 1px solid #eee;
  transition: background-color 0.2s;
}
.order-status-card.data-v-79e6a490:active {
  background-color: #e0e0e0;
}
.card-left.data-v-79e6a490 {
  width: 40px;
  display: flex;
  justify-content: center;
  margin-right: 10px;
}
.card-center.data-v-79e6a490 {
  flex: 1;
}
.status-label.data-v-79e6a490 {
  font-size: 16px;
  color: #333;
}
.card-right.data-v-79e6a490 {
  width: 50px;
  text-align: right;
}
.status-count.data-v-79e6a490 {
  font-size: 20px;
  font-weight: bold;
  color: #007aff;
}
.custom-list-item.data-v-79e6a490 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 15px;
  background-color: #fff;
  border-bottom: 1px solid #f5f5f5;
  font-size: 16px;
  color: #333;
}
.custom-list-item.data-v-79e6a490:active {
  background-color: #f5f5f5;
}
.logout-btn.data-v-79e6a490 {
  margin: 30px 20px;
  border-radius: 8px;
}
